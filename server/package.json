    "transcription",
    "stt",
    "remote",
    "server"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/gunzip-maybe": "^1.4.3",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.5",
    "@types/tar-fs": "^2.0.4",
    "gunzip-maybe": "^1.4.2",
    "tar-fs": "^3.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
